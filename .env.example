# =============================================================================
# Environment Variables for Morine Bakery (Vercel Deployment)
# =============================================================================
# Copy this file to .env.local for local development, or set these in the
# Vercel dashboard (Settings → Environment Variables) for production.

# ---------------------------------------------------------------------------
# Required: Database (PostgreSQL)
# ---------------------------------------------------------------------------
# Vercel Postgres or external PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:5432/morine_bakery"

# ---------------------------------------------------------------------------
# Optional: Logging
# ---------------------------------------------------------------------------
# Log level: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL="info"

# ---------------------------------------------------------------------------
# Optional: Node Environment
# ---------------------------------------------------------------------------
# Set automatically by Vercel. Use "development" for local dev.
NODE_ENV="production"

# ---------------------------------------------------------------------------
# Replit-specific (IGNORE on Vercel — these are set automatically on Replit)
# ---------------------------------------------------------------------------
# PORT=3000          # Set by Replit, not needed on Vercel
# BASE_PATH=/        # Set by Replit, defaults to / on Vercel
# REPL_ID=...        # Set by Replit, not present on Vercel
