{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run build:vercel",
  "outputDirectory": "artifacts/morine-bakery/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api?__path=$1"
    }
  ],
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node@3",
      "memory": 512,
      "maxDuration": 10,
      "includeFiles": "artifacts/api-server/src/**"
    }
  },
  "github": {
    "silent": true
  }
}
